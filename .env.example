# ── Decart Lucy VTON ──────────────────────────────────────────────
# Your PERMANENT Decart key (starts with dct_ or onedct_). Server-side ONLY.
# Get / rotate it at https://platform.decart.ai
DECART_API_KEY=dct_last-one_hUguLSbPTBFnJLPAHiWlVvEEtmKRfadrWXMaVqfMvupUHsnFoxmZKbiDEiyVyGrC



# Realtime VTON model id (see docs.platform.decart.ai/models/realtime/virtual-try-on)
DECART_VTON_MODEL=lucy-vton-latest

# Ephemeral client-token TTL in seconds (1–3600). Official default = 600 (10 min).
# Only bounds the connect handshake; active sessions survive expiry. Token validity
# does not bill you — the 5-second live window in app.js is what caps consumption.
DECART_TOKEN_TTL=600

# Comma-separated origins the minted ek_ token is locked to (server.js reads this).
# Lock to your real origins so a leaked token can't be replayed elsewhere.
DECART_ALLOWED_ORIGINS=http://localhost:3000

# Port for the local server
PORT=3000

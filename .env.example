# ── Decart Lucy VTON ──────────────────────────────────────────────
# Your PERMANENT Decart key (starts with dct_ or onedct_). Server-side ONLY.
# Get / rotate it at https://platform.decart.ai
# ⚠ NEVER put a real key in this committed example file — use a placeholder.
DECART_API_KEY=dct_your_permanent_key_here



# Realtime VTON model id (see docs.platform.decart.ai/models/realtime/virtual-try-on)
DECART_VTON_MODEL=lucy-vton-latest

# Ephemeral client-token TTL in seconds (1–3600). Set to 120 (2 min) for production —
# short enough that a leaked ek_ token expires quickly, long enough to survive the
# connect handshake. The user's "Stop" button is the billing kill-switch; tokens
# that expire while no session is active cost nothing.
DECART_TOKEN_TTL=120

# Comma-separated origins the minted ek_ token is locked to (server.js reads this).
# Lock to your real origins so a leaked token can't be replayed elsewhere.
DECART_ALLOWED_ORIGINS=http://localhost:3000

# Port for the local server
PORT=3000

# ── Google Sheets analytics ──────────────────────────────────────────────────
# Required for try-on events to be logged. Without these, logTryOn() silently
# returns (see lib/sheets.js) — no error is thrown, the try-on still works.
#
# GOOGLE_SHEETS_ID: the spreadsheet ID from the URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# GOOGLE_SERVICE_ACCOUNT_JSON: the full JSON key for a Google Cloud service account
#   that has been granted Editor access to the sheet above.
#   Paste the entire downloaded .json file as a single line (no newlines).
#   Vercel: Settings → Environment Variables — paste directly, Vercel handles escaping.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Sheet tab name (the tab must already exist in the spreadsheet)
GOOGLE_SHEET_TAB=TryOn Analytics

# ── Garment front/back classification ────────────────────────────────────────
# Used by POST /api/classify-images (widget "try front + back" flow), by
# scanner/scan-store.js, and by scripts/batch-scan-clothes.js (one-time catalog
# scan → clothes_metadata.json). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the Gemini model used by scripts/batch-scan-clothes.js
# (defaults to gemini-flash-lite-latest — the Flash LITE tier, cheapest/fastest
# for a front-vs-back call, via Google's rolling "-latest" alias — if unset.
# gemini-2.0-flash-lite/gemini-2.5-flash-lite may return 429/404 on newer keys
# once retired for new callers; verify against your own key before pinning.)
GEMINI_MODEL=gemini-flash-lite-latest

# ── Email OTP verification (first-time visitor identity gate) ────────────────
# Used by POST /api/send-otp to email the 6-digit verification code via Resend.
# Get a key at https://resend.com/api-keys. Without it, /api/send-otp fails
# with 502 and the identity gate's "Continue" surfaces a retry error.
RESEND_API_KEY=your_resend_api_key_here

# ── Admin dashboard authorization ────────────────────────────────────────────
# Comma-separated Supabase Auth emails allowed into the admin dashboard. Required
# to lock the admin API to real admins — without it, ANY account that can sign up
# against the public anon key would be treated as an admin.
ADMIN_EMAILS=you@example.com,partner@example.com

# Comma-separated passwords, one per ADMIN_EMAILS entry, in the SAME ORDER
# (index i pairs with index i). Checked by POST /api/admin/check-auth before a
# magic-link email is sent.
ADMIN_PASSWORDS=

# ── Supabase (session/user storage + admin auth) ─────────────────────────────
# Supabase Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Sheets analytics (alternate var names read by /api/test-sheets) ───
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
